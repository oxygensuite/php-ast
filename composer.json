{
  "name": "oxygensuite/php-ast",
  "type": "package",
  "description": "A lightweight Abstract Syntax Tree (AST) implementation for PHP, enabling structured parsing, analysis, and transformation of PHP code.",
  "keywords": [
    "PHP",
    "AST",
    "Abstract Syntax Tree",
    "Code Transformation",
    "Parser"
  ],
  "license": "MIT",
  "require": {
    "php": "^8.4",
    "ext-ctype": "*",
    "ext-mbstring": "*"
  },
  "require-dev": {
    "laravel/pint": "^1.28",
    "phpunit/phpunit": "^13.0",
    "roave/security-advisories": "dev-latest"
  },
  "autoload": {
    "psr-4": {
      "OxygenSuite\\PhpAst\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit"
  },
  "config": {
    "optimize-autoloader": true,
    "preferred-install": "dist",
    "sort-packages": true
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
